{
  // The default Worker is preview-only. Production must explicitly use --env production.
  "name": "portfolio-website-preview",
  "compatibility_date": "2026-07-07",
  "assets": {
    "directory": "./dist"
  },
  "env": {
    "production": {
      "name": "portfolio-website",
      "routes": [
        { "pattern": "znye6302.com", "custom_domain": true },
        { "pattern": "www.znye6302.com", "custom_domain": true }
      ]
    }
  }
}
